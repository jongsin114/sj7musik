<script>
  // ── 홈에서 시작 ──
  window.history.scrollRestoration = 'manual';
  window.scrollTo(0, 0);

  // ── 커서 (clientX/Y 사용 — 스크롤과 무관) ──
  const cursor = document.getElementById('cursor');
  const ring = document.getElementById('cursorRing');
  let mx = 0, my = 0, rx = 0, ry = 0;

  document.addEventListener('mousemove', (e) => {
    mx = e.clientX;
    my = e.clientY;
    // cursor는 바로 이동
    cursor.style.left = mx + 'px';
    cursor.style.top = my + 'px';
  });

  // ring은 부드럽게 따라옴
  (function animRing() {
    rx += (mx - rx) * 0.12;
    ry += (my - ry) * 0.12;
    ring.style.left = rx + 'px';
    ring.style.top = ry + 'px';
    requestAnimationFrame(animRing);
  })();

  document.querySelectorAll('a, button').forEach(el => {
    el.addEventListener('mouseenter', () => ring.style.transform = 'translate(-50%,-50%) scale(1.8)');
    el.addEventListener('mouseleave', () => ring.style.transform = 'translate(-50%,-50%) scale(1)');
  });

  // ── 스크롤 reveal ──
  const revealEls = document.querySelectorAll(
    '.about-headline, .about-divider, .about-text, .artist-row, .works-col, .coming-soon-wrap'
  );
  const io = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.12 });
  revealEls.forEach(el => io.observe(el));

  // ── 활성 nav ──
  const navLinks = document.querySelectorAll('nav a[data-section]');

  function updateNav() {
    const home = document.getElementById('home');
    const homeBottom = home ? home.getBoundingClientRect().bottom : 0;
    if (homeBottom > window.innerHeight * 0.5) {
      navLinks.forEach(a => a.classList.remove('active'));
      return;
    }
    let current = '';
    ['about', 'artists', 'works', 'news'].forEach(id => {
      const el = document.getElementById(id);
      if (!el) return;
      const { top, bottom } = el.getBoundingClientRect();
      if (top <= window.innerHeight * 0.45 && bottom > 0) current = id;
    });
    const footer = document.getElementById('footer-contact');
    if (footer && footer.getBoundingClientRect().top < window.innerHeight) current = 'contact';
    navLinks.forEach(a => a.classList.toggle('active', a.dataset.section === current));
  }

  window.addEventListener('scroll', updateNav, { passive: true });
  updateNav();

  // ── 스무스 스크롤 ──
  navLinks.forEach(a => {
    a.addEventListener('click', e => {
      e.preventDefault();
      const target = a.dataset.section === 'contact'
        ? document.getElementById('footer-contact')
        : document.getElementById(a.dataset.section);
      if (target) target.scrollIntoView({ behavior: 'smooth' });
    });
  });
</script>