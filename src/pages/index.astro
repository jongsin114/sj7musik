</html>

<script>
  // ── 홈에서 시작 ──
  window.history.scrollRestoration = 'manual';
  window.scrollTo(0, 0);

  // ── 커서 ──
  const cursor = document.getElementById('cursor');
  const ring = document.getElementById('cursorRing');
  let mx = 0, my = 0, rx = 0, ry = 0;

  document.addEventListener('mousemove', (e) => {
    mx = e.clientX;
    my = e.clientY;
    cursor.style.left = mx + 'px';
    cursor.style.top = my + 'px';
  });

  (function animRing() {
    rx += (mx - rx) * 0.12;
    ry += (my - ry) * 0.12;
    ring.style.left = rx + 'px';
    ring.style.top = ry + 'px';
    requestAnimationFrame(animRing);
  })();

  document.querySelectorAll('a, button').forEach(el => {
    el.addEventListener('mouseenter', () => ring.style.transform = 'translate(-50%,-50%) scale(1.8)');
    el.addEventListener('mouseleave', () => ring.style.transform = 'translate(-50%,-50%) scale(1)');
  });

  // ── 스크롤 reveal ──
  const revealEls = document.querySelectorAll(
    '.about-headline, .about-divider, .about-text, .artist-row, .coming-soon-wrap'
  );
  const io = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.12 });
  revealEls.forEach(el => io.observe(el));

  // ── Works 카드 reveal ──
  const worksIo = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.05 });

  // ── 활성 nav ──
  const navLinks = document.querySelectorAll('nav a[data-section]');

  function updateNav() {
    const home = document.getElementById('home');
    const homeBottom = home ? home.getBoundingClientRect().bottom : 0;
    if (homeBottom > window.innerHeight * 0.5) {
      navLinks.forEach(a => a.classList.remove('active'));
      return;
    }
    let current = '';
    ['about', 'artists', 'works', 'news'].forEach(id => {
      const el = document.getElementById(id);
      if (!el) return;
      const { top, bottom } = el.getBoundingClientRect();
      if (top <= window.innerHeight * 0.45 && bottom > 0) current = id;
    });
    const footer = document.getElementById('footer-contact');
    if (footer && footer.getBoundingClientRect().top < window.innerHeight) current = 'contact';
    navLinks.forEach(a => a.classList.toggle('active', a.dataset.section === current));
  }

  window.addEventListener('scroll', updateNav, { passive: true });
  updateNav();

  // ── 스무스 스크롤 ──
  navLinks.forEach(a => {
    a.addEventListener('click', e => {
      e.preventDefault();
      const target = a.dataset.section === 'contact'
        ? document.getElementById('footer-contact')
        : document.getElementById(a.dataset.section);
      if (target) target.scrollIntoView({ behavior: 'smooth' });
    });
  });

  // ── Works 카드 슬라이더 ──
  {
    const worksTrack = document.getElementById('worksTrack');
    const allCards = document.querySelectorAll('.works-card');
    const tabs = document.querySelectorAll('.works-tab');
    let currentCat = 'kpop';
    let wOffsetX = 0;
    let wTouchStartX = 0;
    let wIsDragging = false;
    let wDragStartX = 0;

    function showCategory(cat) {
      currentCat = cat;
      wOffsetX = 0;
      worksTrack.style.transition = 'none';
      worksTrack.style.transform = 'translateX(0)';

      allCards.forEach(card => {
        card.style.display = card.dataset.cat === cat ? 'flex' : 'none';
      });

      setTimeout(() => {
        document.querySelectorAll(`.works-card[data-cat="${cat}"]`).forEach((card, i) => {
          card.style.opacity = '0';
          card.style.transform = 'translateY(20px)';
          setTimeout(() => {
            card.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
            card.style.opacity = '1';
            card.style.transform = 'translateY(0)';
          }, i * 40);
        });
      }, 10);
    }

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        showCategory(tab.dataset.cat);
      });
    });

    function snapToGrid() {
      const visibleCards = document.querySelectorAll(`.works-card[data-cat="${currentCat}"]`);
      if (!visibleCards.length) return;
      const cardW = visibleCards[0].getBoundingClientRect().width + 16;
      const maxOffset = 0;
      const minOffset = -(cardW * (visibleCards.length - 1));
      wOffsetX = Math.max(minOffset, Math.min(maxOffset, wOffsetX));
      const snapped = Math.round(wOffsetX / cardW) * cardW;
      wOffsetX = Math.max(minOffset, Math.min(maxOffset, snapped));
      worksTrack.style.transition = 'transform 0.4s cubic-bezier(0.16, 1, 0.3, 1)';
      worksTrack.style.transform = `translateX(${wOffsetX}px)`;
    }

    // 마우스 드래그
    let wTouchStartY = 0;
worksTrack.addEventListener('touchstart', e => {
  wTouchStartX = e.touches[0].clientX - wOffsetX;
  wTouchStartY = e.touches[0].clientY;
  worksTrack.style.transition = 'none';
}, { passive: true });

worksTrack.addEventListener('touchmove', e => {
  const dx = Math.abs(e.touches[0].clientX - (wTouchStartX + wOffsetX));
  const dy = Math.abs(e.touches[0].clientY - wTouchStartY);
  if (dx > dy) {
    e.preventDefault();
    wOffsetX = e.touches[0].clientX - wTouchStartX;
    worksTrack.style.transform = `translateX(${wOffsetX}px)`;
  }
}, { passive: false });

    // 터치 스와이프
    worksTrack.addEventListener('touchstart', e => {
      wTouchStartX = e.touches[0].clientX - wOffsetX;
      worksTrack.style.transition = 'none';
    }, { passive: true });
    worksTrack.addEventListener('touchmove', e => {
      wOffsetX = e.touches[0].clientX - wTouchStartX;
      worksTrack.style.transform = `translateX(${wOffsetX}px)`;
    }, { passive: true });
    worksTrack.addEventListener('touchend', () => {
      snapToGrid();
    });

    showCategory('kpop');
  }
</script>